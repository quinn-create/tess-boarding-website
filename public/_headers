/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Hashed build assets — content-addressed, safe to cache forever
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Static images — long cache, revalidated on filename change
/images/*
  Cache-Control: public, max-age=2592000

# Fonts shipped via next/font are also under /_next/static, but if any are
# served straight from /public:
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/icon
  Content-Type: image/png
  Cache-Control: public, max-age=86400, immutable

/apple-icon
  Content-Type: image/png
  Cache-Control: public, max-age=86400, immutable

# Crawler-facing files — short cache so policy/sitemap updates propagate
/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/llms.txt
  Cache-Control: public, max-age=3600
